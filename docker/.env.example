# ── Model configuration ──────────────────────────────────────────────────────
# Default Ollama model to use (must be pulled on the host: ollama pull mistral)
DEFAULT_MODEL=mistral

# Ollama REST API URL.
# Local dev: http://localhost:11434
# Docker:    http://host.docker.internal:11434  (set automatically by docker-compose)
OLLAMA_BASE_URL=http://localhost:11434

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Embeddings ───────────────────────────────────────────────────────────────
# Sentence Transformers model name — must be identical at index time and query time
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector store ─────────────────────────────────────────────────────────────
# Path inside the container (mounted as a volume in docker-compose)
VECTOR_STORE_PATH=vector_store/

# ── Document storage ─────────────────────────────────────────────────────────
DOCUMENTS_DIR=data/documents

# ── Retrieval ────────────────────────────────────────────────────────────────
# Number of chunks returned by hybrid search
TOP_K=5
# RRF constant k (higher = smoother fusion, lower = stronger top-rank bias)
RRF_K=60

# ── Semantic cache ───────────────────────────────────────────────────────────
# Cosine similarity threshold for a cache hit (0.0–1.0)
CACHE_SIMILARITY_THRESHOLD=0.92

# Redis connection URL.
# Local dev: redis://localhost:6379
# Docker:    redis://redis:6379  (set automatically by docker-compose)
REDIS_URL=redis://localhost:6379

# Cache entry TTL in seconds (3600 = 1 hour)
CACHE_TTL=3600
